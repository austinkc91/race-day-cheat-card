# Race Day Cheat Card - Environment Variables
# These should be set in your linux-mini-agent .env file

# Required: Claude API key (for the AI agent that generates cheat cards)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Required: Google App Password for sending emails
# Generate at: https://myaccount.google.com/apppasswords
GOOGLE_APP_PASSWORD=your_google_app_password

# Required: Telegram bot token (for receiving cheat cards on your phone)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Optional: Restrict Telegram bot to your user ID
TELEGRAM_ALLOWED_USERS=your_telegram_user_id
